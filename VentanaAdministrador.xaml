<ui:FluentWindow x:Class="Proyecto_GRRLN_expediente.VentanaAdministrador"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Panel de Administración General" 
                 Height="768" Width="1366"
                 WindowStartupLocation="CenterScreen"
                 WindowState="Maximized"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Background="#F0F4F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Sistema de Expedientes - Centro de Control" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFF" BorderThickness="0,0,1,0" BorderBrush="#E2E8F0">
                <StackPanel Margin="15,20,15,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                        <Border Width="45" Height="45" CornerRadius="25" Background="#2196F3" HorizontalAlignment="Left">
                            <ui:SymbolIcon Symbol="Person24" Foreground="White" FontSize="24"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Administrador" FontWeight="Black" FontSize="16" Foreground="#0F172A"/>
                            <TextBlock Text="Panel de Control" FontSize="12" Foreground="#64748B"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="GESTIÓN DEL SISTEMA" FontSize="12" FontWeight="Bold" Foreground="#94A3B8" Margin="5,0,0,10"/>

                    <ui:Button x:Name="BtnMenuUsuarios" Content="Cuentas de Usuario" Icon="People24" 
                               Appearance="Light" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                               Margin="0,0,0,5" Height="40" FontSize="14" Click="BtnMenuUsuarios_Click"/>

                    <TextBlock Text="CATÁLOGOS OFICIALES" FontSize="12" FontWeight="Bold" Foreground="#94A3B8" Margin="5,20,0,10"/>

                    <ui:Button x:Name="BtnMenuSap" Content="Departamentos" Icon="Building24" 
                               Appearance="Light" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                               Margin="0,0,0,5" Height="40" FontSize="14" Click="BtnMenuSap_Click"/>

                    <ui:Button x:Name="BtnMenuOrganismos" Content="Catálogo Organismos" Icon="Flowchart24" 
                               Appearance="Light" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                               Margin="0,0,0,5" Height="40" FontSize="14" Click="BtnMenuOrganismos_Click"/>

                    <ui:Button x:Name="BtnSalir" Content="Cerrar Panel" Icon="SignOut24" 
                               Appearance="Danger" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                               Margin="0,40,0,0" Height="40" FontSize="14" Click="BtnSalir_Click"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="25">

                <Grid x:Name="PanelCatalogoSap" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Catálogo de Departamentos" FontSize="28" FontWeight="Black" Foreground="#0F172A"/>
                        <TextBlock Text="Gestiona las claves y nombres de las áreas para el sistema." FontSize="14" Foreground="#64748B"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E2E8F0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <ui:TextBox x:Name="TxtBuscarSap" Grid.Row="0" PlaceholderText="Buscar por Clave o Descripción..." Icon="Search24" Margin="0,0,0,15" TextChanged="TxtBuscarSap_TextChanged"/>

                                <DataGrid x:Name="GridSaps" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderThickness="1" BorderBrush="#CBD5E1" RowHeight="40" SelectionChanged="GridSaps_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="CLAVE DE DEPTO" Binding="{Binding Clave}" Width="150">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="DESCRIPCIÓN DEL ÁREA" Binding="{Binding Descripcion}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="#E2E8F0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <ui:SymbolIcon Symbol="Building24" Foreground="#2196F3" Margin="0,0,10,0" FontSize="20" VerticalAlignment="Center"/>
                                        <TextBlock Text="Detalles del Área" FontSize="18" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Text="Clave del Departamento" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:TextBox x:Name="TxtClaveSap" PlaceholderText="Ej. 200522142" Margin="0,0,0,15" Icon="NumberSymbol24"/>

                                    <TextBlock Text="Descripción / Nombre" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:TextBox x:Name="TxtDescripcionSap" PlaceholderText="Ej. SUAP TAMPICO" Margin="0,0,0,25"/>

                                    <ui:Button x:Name="BtnGuardarSap" Content="Guardar Departamento" Appearance="Primary" Icon="Save24" HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="BtnGuardarSap_Click"/>
                                    <ui:Button x:Name="BtnLimpiarSap" Content="Limpiar / Nuevo" Appearance="Secondary" Icon="DocumentAdd24" HorizontalAlignment="Stretch" Click="BtnLimpiarSap_Click"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="PanelUsuarios" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Gestión de Personal" FontSize="28" FontWeight="Black" Foreground="#0F172A"/>
                        <TextBlock Text="Administra las cuentas de usuario basándose en la estructura de Fichas PEMEX." FontSize="14" Foreground="#64748B"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E2E8F0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <ui:TextBox x:Name="TxtBuscarUsuario" Grid.Row="0" PlaceholderText="Buscar por Ficha o Nombre..." Icon="Search24" Margin="0,0,0,15" TextChanged="TxtBuscarUsuario_TextChanged"/>
                                <DataGrid x:Name="GridUsuarios" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderThickness="1" BorderBrush="#CBD5E1" RowHeight="40" SelectionChanged="GridUsuarios_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="FICHA (ID)" Binding="{Binding Ficha}" Width="Auto">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="NOMBRE COMPLETO" Binding="{Binding nombre}" Width="*"/>
                                        <DataGridTextColumn Header="ESTRATO" Binding="{Binding Estrato}" Width="Auto"/>
                                        <DataGridTextColumn Header="TIPO" Binding="{Binding tipo}" Width="Auto"/>
                                        <DataGridTextColumn Header="ESTATUS" Binding="{Binding EstatusTexto}" Width="Auto"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="#E2E8F0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <ui:SymbolIcon Symbol="PersonAdd24" Foreground="#2196F3" Margin="0,0,10,0" FontSize="20" VerticalAlignment="Center"/>
                                        <TextBlock Text="Detalles del Empleado" FontSize="18" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Text="Ficha / ID de Usuario" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:TextBox x:Name="TxtFicha" PlaceholderText="Ej. JefeSoporte o 12345" Margin="0,0,0,10" Icon="ContactCard24"/>

                                    <TextBlock Text="Nombre Completo" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:TextBox x:Name="TxtNombreUsuario" PlaceholderText="Ej. Juan Pérez" Margin="0,0,0,10"/>

                                    <TextBlock Text="Correo Electrónico" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:TextBox x:Name="TxtCorreo" PlaceholderText="Ej. juan@pemex.com" Margin="0,0,0,10" Icon="Mail24"/>

                                    <TextBlock x:Name="LblPassword" Text="Contraseña Provisional" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:PasswordBox x:Name="TxtPassword" PlaceholderText="Ingresa contraseña" Margin="0,0,0,10"/>

                                    <TextBlock Text="Estrato / Categoría" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="CmbEstrato" Margin="0,0,0,10" Height="35" SelectionChanged="CmbEstrato_SelectionChanged"/>

                                    <TextBlock Text="Clave del Depto." FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="CmbClaveDepto" IsEditable="True" DisplayMemberPath="DisplayTexto" SelectedValuePath="Clave" Margin="0,0,0,15" Height="35"/>

                                    <TextBlock Text="Tipo de Usuario (Rol de Acceso)" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="CmbRolUsuario" Margin="0,0,0,15" Height="35"/>

                                    <TextBlock Text="Estatus Operativo" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:ToggleSwitch x:Name="ToggleEstatusUsuario" Content="Cuenta Activa (Permitir acceso)" IsChecked="True" Margin="0,0,0,25"/>

                                    <ui:Button x:Name="BtnGuardarUsuario" Content="Guardar Usuario" Appearance="Primary" Icon="Save24" HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="BtnGuardarUsuario_Click"/>
                                    <ui:Button x:Name="BtnLimpiarUsuario" Content="Limpiar / Nuevo" Appearance="Secondary" Icon="DocumentAdd24" HorizontalAlignment="Stretch" Click="BtnLimpiarUsuario_Click"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="PanelOrganismos" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Catálogo de Organismos PEMEX" FontSize="28" FontWeight="Black" Foreground="#0F172A"/>
                        <TextBlock Text="Actualiza y administra las claves y descripciones oficiales de la institución." FontSize="14" Foreground="#64748B"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E2E8F0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <ui:TextBox x:Name="TxtBuscarOrganismo" Grid.Row="0" PlaceholderText="Buscar por Organismo (PMXC) o Descripción..." Icon="Search24" Margin="0,0,0,15" TextChanged="TxtBuscarOrganismo_TextChanged"/>

                                <DataGrid x:Name="GridOrganismos" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderThickness="1" BorderBrush="#CBD5E1" RowHeight="40" SelectionChanged="GridOrganismos_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="ORGANISMO" Binding="{Binding Clave}" Width="150">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Black"/>
                                                    <Setter Property="Foreground" Value="#0F172A"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="DESCRIPCIÓN COMPLETA" Binding="{Binding Descripcion}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="#E2E8F0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <ui:SymbolIcon Symbol="Flowchart24" Foreground="#2196F3" Margin="0,0,10,0" FontSize="20" VerticalAlignment="Center"/>
                                        <TextBlock Text="Detalles del Organismo" FontSize="18" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Text="ID Interno (Automático)" FontSize="12" FontWeight="SemiBold" Foreground="#94A3B8" Margin="0,0,0,5"/>
                                    <ui:TextBox x:Name="TxtIdOrganismo" IsEnabled="False" PlaceholderText="Se asigna solo al guardar" Margin="0,0,0,15" Icon="NumberSymbol24"/>

                                    <TextBlock Text="Clave (Siglas)" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:TextBox x:Name="TxtClaveOrganismo" PlaceholderText="Ej. PMXC" Margin="0,0,0,15"/>

                                    <TextBlock Text="Descripción / Nombre Completo" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:TextBox x:Name="TxtDescripcionOrganismo" PlaceholderText="Ej. PEMEX CORPORATIVO" Margin="0,0,0,25"/>

                                    <ui:Button x:Name="BtnGuardarOrganismo" Content="Guardar Organismo" Appearance="Primary" Icon="Save24" HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="BtnGuardarOrganismo_Click"/>
                                    <ui:Button x:Name="BtnLimpiarOrganismo" Content="Limpiar / Nuevo" Appearance="Secondary" Icon="DocumentAdd24" HorizontalAlignment="Stretch" Click="BtnLimpiarOrganismo_Click"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>