<ui:FluentWindow x:Class="Proyecto_GRRLN_expediente.VentanaAdministrador"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Panel de Administración General" 
                 Height="768" Width="1366"
                 WindowStartupLocation="CenterScreen"
                 WindowState="Maximized"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Background="#F0F4F8">
                 
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Sistema de Expedientes - Centro de Control" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFF" BorderThickness="0,0,1,0" BorderBrush="#E2E8F0">
                <StackPanel Margin="15,20,15,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                        <Border Width="45" Height="45" CornerRadius="25" Background="#2196F3" HorizontalAlignment="Left">
                            <ui:SymbolIcon Symbol="Person24" Foreground="White" FontSize="24"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Administrador" FontWeight="Black" FontSize="16" Foreground="#0F172A"/>
                            <TextBlock Text="Panel de Control" FontSize="12" Foreground="#64748B"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="GESTIÓN DEL SISTEMA" FontSize="12" FontWeight="Bold" Foreground="#94A3B8" Margin="5,0,0,10"/>

                    <ui:Button x:Name="BtnMenuUsuarios" Content="Cuentas de Usuario" Icon="People24" 
                               Appearance="Light" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                               Margin="0,0,0,5" Height="40" FontSize="14" Command="{Binding MostrarMenuCommand}" CommandParameter="Usuarios"/>

                    <TextBlock Text="CATÁLOGOS OFICIALES" FontSize="12" FontWeight="Bold" Foreground="#94A3B8" Margin="5,20,0,10"/>

                    <ui:Button x:Name="BtnMenuSap" Content="Departamentos" Icon="Building24" 
                               Appearance="Light" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                               Margin="0,0,0,5" Height="40" FontSize="14" Command="{Binding MostrarMenuCommand}" CommandParameter="Departamentos"/>

                    <ui:Button x:Name="BtnMenuOrganismos" Content="Catálogo Organismos" Icon="Flowchart24" 
                               Appearance="Light" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                               Margin="0,0,0,5" Height="40" FontSize="14" Command="{Binding MostrarMenuCommand}" CommandParameter="Organismos"/>

                    <TextBlock Text="SEGURIDAD Y RECUPERACIÓN" FontSize="12" FontWeight="Bold" Foreground="#94A3B8" Margin="5,20,0,10"/>

                    <ui:Button x:Name="BtnMenuPapelera" Content="Expedientes Eliminados" Icon="DeleteDismiss24" 
                               Appearance="Light" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                               Margin="0,0,0,5" Height="40" FontSize="14" Command="{Binding MostrarMenuCommand}" CommandParameter="Papelera"/>

                    <ui:Button x:Name="BtnSalir" Content="Cerrar Panel" Icon="SignOut24" 
                               Appearance="Danger" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                               Margin="0,40,0,0" Height="40" FontSize="14" Command="{Binding SalirCommand}"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="25">

                <Grid x:Name="PanelCatalogoSap" Visibility="{Binding IsPanelSapVisible, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Catálogo de Departamentos" FontSize="28" FontWeight="Black" Foreground="#0F172A"/>
                        <TextBlock Text="Gestiona las claves y nombres de las áreas para el sistema." FontSize="14" Foreground="#64748B"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E2E8F0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <ui:TextBox x:Name="TxtBuscarSap" Grid.Row="0" PlaceholderText="Buscar por Clave o Descripción..." Icon="Search24" Margin="0,0,0,15" Text="{Binding TextoBuscarSap, UpdateSourceTrigger=PropertyChanged}"/>

                                <DataGrid x:Name="GridSaps" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderThickness="1" BorderBrush="#CBD5E1" RowHeight="40" ItemsSource="{Binding ListaSaps}" SelectedItem="{Binding SapSeleccionado}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="CLAVE DE DEPTO" Binding="{Binding Clave}" Width="150">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="DESCRIPCIÓN DEL ÁREA" Binding="{Binding Descripcion}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="#E2E8F0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <ui:SymbolIcon Symbol="Building24" Foreground="#2196F3" Margin="0,0,10,0" FontSize="20" VerticalAlignment="Center"/>
                                        <TextBlock Text="Detalles del Área" FontSize="18" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Text="Clave del Departamento" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:TextBox x:Name="TxtClaveSap" PlaceholderText="Ej. 200522142" Margin="0,0,0,15" Icon="NumberSymbol24" Text="{Binding ClaveSap, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsClaveSapEnabled}"/>

                                    <TextBlock Text="Descripción / Nombre" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:TextBox x:Name="TxtDescripcionSap" PlaceholderText="Ej. SUAP TAMPICO" Margin="0,0,0,25" Text="{Binding DescripcionSap, UpdateSourceTrigger=PropertyChanged}"/>

                                    <ui:Button x:Name="BtnGuardarSap" Content="{Binding TextoBotonGuardarSap}" Appearance="Primary" Icon="Save24" HorizontalAlignment="Stretch" Margin="0,0,0,10" Command="{Binding GuardarSapCommand}"/>
                                    <ui:Button x:Name="BtnLimpiarSap" Content="Limpiar / Nuevo" Appearance="Secondary" Icon="DocumentAdd24" HorizontalAlignment="Stretch" Command="{Binding LimpiarSapCommand}"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="PanelUsuarios" Visibility="{Binding IsPanelUsuariosVisible, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Gestión de Personal" FontSize="28" FontWeight="Black" Foreground="#0F172A"/>
                        <TextBlock Text="Administra las cuentas de usuario basándose en la estructura de Fichas PEMEX." FontSize="14" Foreground="#64748B"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E2E8F0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <ui:TextBox x:Name="TxtBuscarUsuario" Grid.Row="0" PlaceholderText="Buscar por Ficha o Nombre..." Icon="Search24" Margin="0,0,0,15" Text="{Binding TextoBuscarUsuario, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGrid x:Name="GridUsuarios" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderThickness="1" BorderBrush="#CBD5E1" RowHeight="40" ItemsSource="{Binding ListaUsuarios}" SelectedItem="{Binding UsuarioSeleccionado}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="FICHA (ID)" Binding="{Binding Ficha}" Width="Auto">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="NOMBRE COMPLETO" Binding="{Binding nombre}" Width="*"/>
                                        <DataGridTextColumn Header="ESTRATO" Binding="{Binding Estrato}" Width="Auto"/>
                                        <DataGridTextColumn Header="TIPO" Binding="{Binding tipo}" Width="Auto"/>
                                        <DataGridTextColumn Header="ESTATUS" Binding="{Binding EstatusTexto}" Width="Auto"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="#E2E8F0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <ui:SymbolIcon Symbol="PersonAdd24" Foreground="#2196F3" Margin="0,0,10,0" FontSize="20" VerticalAlignment="Center"/>
                                        <TextBlock Text="Detalles del Empleado" FontSize="18" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Text="Ficha / ID de Usuario" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:TextBox x:Name="TxtFicha" PlaceholderText="Ej. JefeSoporte o 12345" Margin="0,0,0,10" Icon="ContactCard24" Text="{Binding FichaUsuario, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsFichaUsuarioEnabled}"/>

                                    <TextBlock Text="Nombre Completo" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:TextBox x:Name="TxtNombreUsuario" PlaceholderText="Ej. Juan Pérez" Margin="0,0,0,10" Text="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Correo Electrónico" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:TextBox x:Name="TxtCorreo" PlaceholderText="Ej. juan@pemex.com" Margin="0,0,0,10" Icon="Mail24" Text="{Binding CorreoUsuario, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock x:Name="LblPassword" Text="Contraseña Provisional" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:PasswordBox x:Name="TxtPassword" PlaceholderText="Ingresa contraseña" Margin="0,0,0,10" PasswordChanged="TxtPassword_PasswordChanged"/>

                                    <TextBlock Text="Estrato / Categoría" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="CmbEstrato" Margin="0,0,0,10" Height="35" ItemsSource="{Binding ListaEstratos}" SelectedItem="{Binding EstratoSeleccionado}"/>

                                    <TextBlock Text="Clave del Depto." FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="CmbClaveDepto" IsEditable="True" DisplayMemberPath="DisplayTexto" SelectedValuePath="Clave" Margin="0,0,0,15" Height="35" ItemsSource="{Binding ListaDepartamentosCmb}" SelectedItem="{Binding DeptoSeleccionado}"/>

                                    <TextBlock Text="Tipo de Usuario (Rol de Acceso)" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="CmbRolUsuario" Margin="0,0,0,15" Height="35" ItemsSource="{Binding ListaRoles}" SelectedItem="{Binding RolSeleccionado}"/>

                                    <TextBlock Text="Estatus Operativo" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:ToggleSwitch x:Name="ToggleEstatusUsuario" Content="Cuenta Activa (Permitir acceso)" IsChecked="{Binding IsEstatusUsuarioActivo}" Margin="0,0,0,25"/>

                                    <ui:Button x:Name="BtnGuardarUsuario" Content="{Binding TextoBotonGuardarUsuario}" Appearance="Primary" Icon="Save24" HorizontalAlignment="Stretch" Margin="0,0,0,10" Command="{Binding GuardarUsuarioCommand}"/>
                                    <ui:Button x:Name="BtnLimpiarUsuario" Content="Limpiar / Nuevo" Appearance="Secondary" Icon="DocumentAdd24" HorizontalAlignment="Stretch" Command="{Binding LimpiarUsuarioCommand}"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="PanelOrganismos" Visibility="{Binding IsPanelOrganismosVisible, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Catálogo de Organismos PEMEX" FontSize="28" FontWeight="Black" Foreground="#0F172A"/>
                        <TextBlock Text="Actualiza y administra las claves y descripciones oficiales de la institución." FontSize="14" Foreground="#64748B"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E2E8F0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <ui:TextBox x:Name="TxtBuscarOrganismo" Grid.Row="0" PlaceholderText="Buscar por Organismo (PMXC) o Descripción..." Icon="Search24" Margin="0,0,0,15" Text="{Binding TextoBuscarOrganismo, UpdateSourceTrigger=PropertyChanged}"/>

                                <DataGrid x:Name="GridOrganismos" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderThickness="1" BorderBrush="#CBD5E1" RowHeight="40" ItemsSource="{Binding ListaOrganismos}" SelectedItem="{Binding OrganismoSeleccionado}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="ORGANISMO" Binding="{Binding Clave}" Width="150">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Black"/>
                                                    <Setter Property="Foreground" Value="#0F172A"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="DESCRIPCIÓN COMPLETA" Binding="{Binding Descripcion}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="#E2E8F0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <ui:SymbolIcon Symbol="Flowchart24" Foreground="#2196F3" Margin="0,0,10,0" FontSize="20" VerticalAlignment="Center"/>
                                        <TextBlock Text="Detalles del Organismo" FontSize="18" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Text="ID Interno (Automático)" FontSize="12" FontWeight="SemiBold" Foreground="#94A3B8" Margin="0,0,0,5"/>
                                    <ui:TextBox x:Name="TxtIdOrganismo" IsEnabled="False" PlaceholderText="Se asigna solo al guardar" Margin="0,0,0,15" Icon="NumberSymbol24" Text="{Binding IdOrganismo}"/>

                                    <TextBlock Text="Clave (Siglas)" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:TextBox x:Name="TxtClaveOrganismo" PlaceholderText="Ej. PMXC" Margin="0,0,0,15" Text="{Binding ClaveOrganismo, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Text="Descripción / Nombre Completo" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,5"/>
                                    <ui:TextBox x:Name="TxtDescripcionOrganismo" PlaceholderText="Ej. PEMEX CORPORATIVO" Margin="0,0,0,25" Text="{Binding DescripcionOrganismo, UpdateSourceTrigger=PropertyChanged}"/>

                                    <ui:Button x:Name="BtnGuardarOrganismo" Content="{Binding TextoBotonGuardarOrganismo}" Appearance="Primary" Icon="Save24" HorizontalAlignment="Stretch" Margin="0,0,0,10" Command="{Binding GuardarOrganismoCommand}"/>
                                    <ui:Button x:Name="BtnLimpiarOrganismo" Content="Limpiar / Nuevo" Appearance="Secondary" Icon="DocumentAdd24" HorizontalAlignment="Stretch" Command="{Binding LimpiarOrganismoCommand}"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
                
                <!-- MODULO: PAPELERA (EXPEDIENTES ELIMINADOS) -->
                <Grid x:Name="PanelPapelera" Visibility="{Binding IsPanelPapeleraVisible, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Papelera de Reciclaje" FontSize="28" FontWeight="Black" Foreground="#C0392B"/>
                        <TextBlock Text="Listado de expedientes con borrado lógico. Aquí puedes recuperarlos si fue un error." FontSize="14" Foreground="#64748B"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E2E8F0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                                <ui:TextBox PlaceholderText="Filtrar eliminados..." Width="300" Icon="Search24" Margin="0,0,15,0" 
                                            Text="{Binding TextoBuscarPapelera, UpdateSourceTrigger=PropertyChanged}"/>
                                <ui:Button Content="Actualizar Lista" Icon="ArrowClockwise24" Command="{Binding CargarEliminadosCommand}"/>
                            </StackPanel>

                            <DataGrid Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="White" 
                                      BorderThickness="1" BorderBrush="#CBD5E1" RowHeight="50" 
                                      ItemsSource="{Binding ListaEliminados}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="FOLIO" Binding="{Binding IdAsunto}" Width="70"/>
                                    <DataGridTextColumn Header="ASUNTO" Binding="{Binding AsuntoNombre}" Width="150"/>
                                    <DataGridTextColumn Header="FECHA DE BAJA" Binding="{Binding FechaEliminacion}" Width="130"/>
                                    <DataGridTextColumn Header="MOTIVO DE BAJA" Binding="{Binding MotivoEliminacion}" Width="*"/>
                                    <DataGridTextColumn Header="ELIMINADO POR" Binding="{Binding UsuarioElimino}" Width="120"/>
                                    <DataGridTemplateColumn Header="ACCIONES" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ui:Button Content="Restaurar" Icon="ArrowReset24" 
                                                           Appearance="Primary" Padding="5,2" Height="30"
                                                           Command="{Binding DataContext.RestaurarExpedienteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                           CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>