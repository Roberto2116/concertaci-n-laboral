<UserControl x:Class="Proyecto_GRRLN_expediente.VistaInicio"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="Transparent">

    <Grid Margin="30,30,30,80">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="TU BANDEJA DE AVISOS" FontSize="24" FontWeight="Black" Foreground="#0F172A"/>
                <TextBlock Text="Notificaciones recientes y comunicados oficiales" FontSize="14" Foreground="#64748B" Margin="0,2,0,0"/>
            </StackPanel>

            <Button x:Name="BtnArchivarTodo" Grid.Column="1" Width="50" Height="50" 
                    Cursor="Hand" ToolTip="Archivar todos los mensajes" 
                    VerticalAlignment="Center" Margin="15,0,0,0"
                    Command="{Binding ArchivarTodoCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="FondoBoton" Background="#EBF5FB" CornerRadius="6">
                            <ui:SymbolIcon Symbol="Archive24" Foreground="#2E86C1" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FondoBoton" Property="Background" Value="#D6EAF8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FondoBoton" Property="Background" Value="#AED6F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <Grid Grid.Row="1">

            <StackPanel x:Name="PanelSinAvisos" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding PanelSinAvisosVisibility}">
                <ui:SymbolIcon Symbol="Mail24" FontSize="64" Foreground="#CBD5E1" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBlock Text="¡Estás al día!" FontSize="20" FontWeight="Bold" Foreground="#475569" HorizontalAlignment="Center"/>
                <TextBlock Text="No tienes notificaciones pendientes de leer." Foreground="#94A3B8" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="icAvisos" ItemsSource="{Binding Avisos}" Visibility="{Binding ListaAvisosVisibility}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="8" Margin="0,0,10,15" Padding="20" 
                                    BorderThickness="4,1,1,1" BorderBrush="{Binding HexColor}">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                                </Border.Effect>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="{Binding Emisor}" FontWeight="Bold" FontSize="16" Foreground="#0F172A" VerticalAlignment="Center"/>
                                            <TextBlock Text="•" Foreground="#CBD5E1" Margin="8,0" VerticalAlignment="Center" FontSize="16"/>
                                            <ui:SymbolIcon Symbol="{Binding AvisoSymbol}" Foreground="{Binding ColorEtiqueta}" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                            <Border Background="{Binding ColorEtiqueta}" CornerRadius="12" Padding="10,2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TextoEtiqueta}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>

                                        <TextBlock Text="{Binding TextoMensaje}" TextWrapping="Wrap" FontSize="14" Foreground="#475569" LineHeight="22" Margin="0,0,0,10"/>

                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Clock24" FontSize="12" Foreground="#94A3B8" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Fecha}" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="1" Width="36" Height="36" Cursor="Hand" ToolTip="Archivar este mensaje" 
                                            VerticalAlignment="Center" Margin="15,0,0,0"
                                            Command="{Binding DataContext.ArchivarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="FondoBotonCard" Background="#EBF5FB" CornerRadius="6">
                                                    <ui:SymbolIcon Symbol="Archive24" Foreground="#2E86C1" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="FondoBotonCard" Property="Background" Value="#D6EAF8"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="FondoBotonCard" Property="Background" Value="#AED6F1"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>