<ui:FluentWindow x:Class="Proyecto_GRRLN_expediente.VentanaActualizarAvance"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Actualizar Avance" Height="250" Width="350"
                 WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ACTUALIZAR AVANCE" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock x:Name="LblExpediente" Grid.Row="1" Text="{Binding TituloExpediente}" FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="2" VerticalAlignment="Center">
            <Slider x:Name="SldAvance" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" 
                    Margin="10,0" Value="{Binding Avance, UpdateSourceTrigger=PropertyChanged}" Cursor="Hand" Height="26" Width="291"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <TextBox x:Name="TxtPorcentaje" Text="{Binding AvanceTexto, UpdateSourceTrigger=PropertyChanged}" FontSize="24" FontWeight="Bold" Foreground="#27ae60" 
                         BorderThickness="0" Background="Transparent" TextAlignment="Center" MinWidth="30"
                         PreviewTextInput="TxtPorcentaje_PreviewTextInput"/>
                <TextBlock Text="%" FontSize="24" FontWeight="Bold" Foreground="#27ae60" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Cancelar" Width="100" Height="35" Background="#e74c3c" Foreground="White" FontWeight="Bold" Margin="0,0,15,0" Command="{Binding CancelarCommand}" Cursor="Hand"/>
            <Button Content="Guardar" Width="100" Height="35" Background="#27ae60" Foreground="White" FontWeight="Bold" Command="{Binding GuardarCommand}" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>