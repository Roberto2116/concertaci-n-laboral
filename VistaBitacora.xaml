<ui:FluentWindow x:Class="Proyecto_GRRLN_expediente.VistaBitacora"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Bitácora de Seguimiento" Height="750" Width="1000"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="1" Margin="30,10,30,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
                <ui:Button Content="Cerrar Bitácora" Icon="Dismiss24" Appearance="Secondary" 
                           Height="36" Cursor="Hand" Margin="0,0,15,0" 
                           Command="{Binding RegresarCommand}"/>
                <TextBlock x:Name="TxtTitulo" Text="{Binding TituloBitacora}" FontSize="22" FontWeight="Black" Foreground="#2C3E50" VerticalAlignment="Center"/>
            </StackPanel>

            <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#EAEDED" BorderThickness="1" Padding="25" Margin="0,0,0,25">
                <Border.Effect>
                    <DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
                </Border.Effect>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <ui:SymbolIcon Symbol="AddSquare24" Foreground="#00843D" Margin="0,0,8,0"/>
                        <TextBlock Text="Agregar Nuevo Avance:" FontSize="15" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBox x:Name="TxtNuevaBitacora" 
                             Text="{Binding NuevaBitacora, UpdateSourceTrigger=PropertyChanged}"
                             CharacterCasing="Upper" 
                             Height="90" 
                             TextWrapping="Wrap" 
                             AcceptsReturn="True" 
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top" 
                             Padding="12" Margin="0,0,0,15"
                             FontSize="14"
                             BorderBrush="#BDC3C7" BorderThickness="1" Background="#FAFCFC"/>

                    <Button Width="180" Height="40" HorizontalAlignment="Right" Cursor="Hand" Command="{Binding GuardarCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border x:Name="FondoBoton" Background="#00843D" CornerRadius="6">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <ui:SymbolIcon Symbol="Save24" Foreground="White" Margin="0,0,8,0"/>
                                        <TextBlock Text="Guardar Avance" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="FondoBoton" Property="Background" Value="#00A84D"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="FondoBoton" Property="Background" Value="#005C2B"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>

                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="White" CornerRadius="8" BorderBrush="#EAEDED" BorderThickness="1">
                <DataGrid x:Name="dgBitacora" ItemsSource="{Binding ListaHistorial}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
                          SelectionMode="Single" FontSize="14" Background="Transparent" BorderThickness="0"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F4F6F6"
                          AlternatingRowBackground="#FAFCFC">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9FA"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="#7F8C8D"/>
                            <Setter Property="Padding" Value="15,12"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#E5E7E9"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="N° BITÁCORA" Binding="{Binding IdBitacora}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="10,0,0,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="FECHA" Binding="{Binding Fecha}" Width="160">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="5"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="DESCRIPCIÓN DEL AVANCE" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Descripcion}" TextWrapping="Wrap" Padding="10,8" Foreground="#444444"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

        </Grid>
    </Grid>
</ui:FluentWindow>