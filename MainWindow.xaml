<ui:FluentWindow x:Class="Proyecto_GRRLN_expediente.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Agenda laboral - Gestión Multi-Sede" 
        WindowState="Maximized"
        ResizeMode="NoResize"
        MinHeight="720" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Agenda Laboral" 
                     ShowMinimize="False" 
                     ShowMaximize="False" 
                     ShowClose="False" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="MenuLateral" Background="#F8F9FA" Grid.Column="0" BorderBrush="#E5E7E9" BorderThickness="0,0,1,0">
                <StackPanel Margin="15">

                    <Border Background="#E5F3EB" Width="60" Height="60" CornerRadius="30" Margin="0,10,0,10">
                        <ui:SymbolIcon Symbol="BuildingBank24" FontSize="30" Foreground="#00843D" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="AGENDA LABORAL" Foreground="#2C3E50" FontSize="16" FontWeight="Black" Margin="0,5,0,30" HorizontalAlignment="Center"/>

                    <ui:Button x:Name="BtnExpedientes" Content="SEGUIMIENTO" Icon="TextBulletListLtr24" 
                               Appearance="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                               Height="45" Margin="0,5" FontWeight="SemiBold" Command="{Binding NavegarExpedientesCommand}"/>

                    <ui:Button x:Name="BtnNuevoCaso" Content="NUEVO ASUNTO" Icon="AddDocument24" 
                               Appearance="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                               Height="45" Margin="0,5" FontWeight="SemiBold" Command="{Binding NavegarNuevoCasoCommand}"/>

                    <ui:Button x:Name="Btnconsultas" Content="CONSULTA GENERAL" Icon="Search24" 
                               Appearance="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                               Height="45" Margin="0,5" FontWeight="SemiBold" Command="{Binding NavegarConsultasCommand}"/>

                    <ui:Button x:Name="BtnEstadisticas" Content="ESTADÍSTICAS" Icon="DataPie24" 
                               Appearance="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                               Height="45" Margin="0,5" FontWeight="SemiBold" Command="{Binding NavegarEstadisticasCommand}"/>

                    <Separator Margin="0,20" Background="#EAEDED"/>

                    <Button x:Name="BtnNuevoAvisoGlobal" Height="45" Margin="0,5" HorizontalAlignment="Stretch" 
                            Cursor="Hand" Command="{Binding NavegarNuevoAvisoCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="FondoBoton" Background="#00843D" CornerRadius="4">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                                        <ui:SymbolIcon Symbol="Megaphone24" Foreground="White" Margin="0,0,10,0"/>
                                        <TextBlock Text="NUEVO AVISO" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="FondoBoton" Property="Background" Value="#00A84D"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="FondoBoton" Property="Background" Value="#005C2B"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <ui:Button x:Name="BtnAdministracion" Content="ADMINISTRACIÓN" 
                               Appearance="Transparent" Foreground="#1E3A8A" 
                               HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                               Height="45" Margin="0,40,0,5" FontWeight="Black" 
                               ToolTip="Acceso restringido: Solo Administradores"
                               Command="{Binding NavegarAdministracionCommand}">

                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="ShieldKeyhole24" Foreground="#FBBF24" FontSize="32"/>
                        </ui:Button.Icon>
                    </ui:Button>

                    <ui:Button x:Name="BtnSalir" Content="Cerrar Sesión" Icon="SignOut24" 
                               Appearance="Secondary" Foreground="#C8102E"
                               HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                               Height="45" Margin="0,5,0,0" FontWeight="Bold" Command="{Binding SalirCommand}"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Background="Transparent">
                <ContentControl x:Name="ContenedorPrincipal" 
                                HorizontalContentAlignment="Stretch" 
                                VerticalContentAlignment="Stretch"
                                Margin="0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Bienvenido al Sistema de Gestión" FontSize="26" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                        <TextBlock Text="Seleccione una opción del menú de la izquierda para comenzar" FontSize="15" HorizontalAlignment="Center" Foreground="#7F8C8D" Margin="0,10,0,0"/>
                    </StackPanel>
                </ContentControl>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>