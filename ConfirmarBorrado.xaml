<ui:FluentWindow x:Class="Proyecto_GRRLN_expediente.ConfirmarBorrado"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Autorización de Seguridad" Height="430" Width="429"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 ResizeMode="NoResize">

    <Grid Background="#FDFEFE">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Validación de Credenciales" />

        <StackPanel Grid.Row="1" Margin="25,10,25,25">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <ui:SymbolIcon Symbol="ShieldLock24" Foreground="#C0392B" FontSize="28" Margin="0,0,12,0"/>
                <TextBlock Text="Confirmación Requerida" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="{Binding MensajeAutorizacion}" 
                       TextWrapping="Wrap" Foreground="#566573" FontSize="13" Margin="0,0,0,15"/>

            <TextBlock Text="Motivo de la baja (Obligatorio):" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
            <ui:TextBox x:Name="TxtMotivo" 
                        PlaceholderText="Describa brevemente por qué se elimina este expediente..."
                        Text="{Binding Motivo, UpdateSourceTrigger=PropertyChanged}"
                        Height="70" 
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        Margin="0,0,0,15"/>

            <TextBlock Text="Su contraseña para autorizar:" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
            <PasswordBox x:Name="TxtPasswordConfirm" 
                         Height="38" 
                         FontSize="16"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,25"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ui:Button Grid.Column="0" 
                           Content="Cancelar" 
                           Appearance="Secondary" 
                           HorizontalAlignment="Stretch" 
                           Margin="0,0,5,0"
                           Height="40"
                           Command="{Binding CancelarCommand}"/>

                <Button Grid.Column="1" x:Name="BtnAutorizar" HorizontalAlignment="Stretch" Margin="5,0,0,0" Height="40" Cursor="Hand" Command="{Binding AutorizarCommand}" CommandParameter="{Binding ElementName=TxtPasswordConfirm}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="FondoBoton" Background="#C0392B" CornerRadius="6">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ui:SymbolIcon Symbol="Checkmark24" Foreground="White" Margin="0,0,8,0"/>
                                    <TextBlock Text="AUTORIZAR" Foreground="White" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="FondoBoton" Property="Background" Value="#E74C3C"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="FondoBoton" Property="Background" Value="#943126"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</ui:FluentWindow>