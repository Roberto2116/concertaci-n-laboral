<ui:FluentWindow x:Class="Proyecto_GRRLN_expediente.VistaConsultaGeneral"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Consulta General de Asuntos" 
                 Height="720" Width="1280"
                 WindowStartupLocation="CenterScreen"
                 WindowState="Maximized" 
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Sistema de Expedientes - Búsqueda" />

        <Grid Grid.Row="1" Margin="20,10,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
                <ui:Button Content="Cerrar Búsqueda" Icon="Dismiss24" Appearance="Secondary" 
                           Height="36" Cursor="Hand" Margin="0,0,15,0" 
                           Click="BtnRegresar_Click"/>
                <TextBlock Text="SEGUIMIENTO GENERAL DE ASUNTOS" FontSize="22" FontWeight="Black" Foreground="#2C3E50" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                <ui:TextBox x:Name="TxtBuscar" Width="450" Height="38" FontSize="14" 
                    PlaceholderText="Buscar folio, asunto, departamento o SAP..." 
                    Icon="Search24" ClearButtonEnabled="True"
                    TextChanged="TxtBuscar_TextChanged"/>
            </StackPanel>

            <Border Grid.Row="2" Background="White" CornerRadius="8" BorderBrush="#EAEDED" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="1" Opacity="0.3"/>
                </Border.Effect>

                <DataGrid x:Name="GridAsuntos" AutoGenerateColumns="False" CanUserAddRows="False"
                          Background="Transparent" BorderThickness="0" RowHeight="55"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F4F6F6"
                          AlternatingRowBackground="#FAFCFC">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9FA"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="#7F8C8D"/>
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#E5E7E9"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="FOLIO" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Click="BtnEditar_Click" 
                                            DataContext="{Binding}"
                                            Cursor="Hand"
                                            HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"
                                            ToolTip="Haz clic para editar este asunto">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock x:Name="TxtLink" Text="{Binding Id}" 
                                                           Foreground="#2980B9" FontWeight="Bold" 
                                                           TextDecorations="Underline" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="TxtLink" Property="Foreground" Value="#1A5276"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="ASUNTO" Binding="{Binding Asunto}" Width="1.5*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="5"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="DESCRIPCIÓN" Binding="{Binding DescripcionCortaTexto}" Width="2*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="Foreground" Value="#555555"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="SAP" Binding="{Binding Sap}" Width="120" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="DEPARTAMENTO" Binding="{Binding Departamento}" Width="1.5*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="Foreground" Value="#555555"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="GERENCIA" Binding="{Binding GerenciaTexto}" Width="110" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="5"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="FECHA LÍM" Binding="{Binding FechaLimite}" Width="100" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="5"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="AVANCE" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Margin="10,5">
                                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding Avance}" 
                                                     Height="12" Foreground="#00843D" Background="#EAECEE" BorderThickness="0"
                                                     VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding AvanceTexto}" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                   FontSize="11" FontWeight="Bold" Foreground="#333" Margin="0,-22,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="ESTATUS" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding ColorSemaforo}" CornerRadius="12" Padding="8,5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TextoDias}" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                   FontWeight="Bold" Foreground="White" FontSize="11"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>