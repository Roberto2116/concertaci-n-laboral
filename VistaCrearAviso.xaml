<ui:FluentWindow x:Class="Proyecto_GRRLN_expediente.VistaCrearAviso"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Crear Notificación" Height="750" Width="1200"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Background="Transparent" 
                 Loaded="UserControl_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="1" Margin="20,10,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,0,0,20">
                <ui:Button Content="Volver al Menú" Icon="ArrowLeft24" Appearance="Secondary" 
                           Height="36" Cursor="Hand" Margin="0,0,15,0" 
                           Command="{Binding RegresarCommand}"/>
                <TextBlock Text="CENTRO DE COMUNICACIONES" FontSize="22" FontWeight="Black" Foreground="#2C3E50" VerticalAlignment="Center"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Border Background="White" CornerRadius="8" HorizontalAlignment="Stretch" VerticalAlignment="Top" 
                            BorderBrush="#EAEDED" BorderThickness="1" Padding="30,30">
                        <Border.Effect>
                            <DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
                        </Border.Effect>

                        <StackPanel>
                            <Border Background="#F8F9FA" Padding="20" CornerRadius="8" BorderBrush="#E5E7E9" BorderThickness="1" Margin="0,0,0,25">
                                <StackPanel>
                                    <TextBlock Text="1. Seleccione el alcance del mensaje:" FontSize="15" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="RbUsuario" Content="Un Usuario" IsChecked="{Binding IsAlcanceUsuario}" FontSize="14" Margin="0,0,20,0"/>
                                        <RadioButton x:Name="RbDepto" Content="Un Departamento" IsChecked="{Binding IsAlcanceDepto}" FontSize="14" Margin="0,0,20,0"/>
                                        <RadioButton x:Name="RbSAP" Content="Aviso Global (Todos)" IsChecked="{Binding IsAlcanceSAP}" FontSize="14"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="LblDestinatario" Text="2. Seleccione el Destinatario:" FontSize="15" FontWeight="Bold" Margin="0,0,0,10" Foreground="#2C3E50"/>
                            <ComboBox x:Name="CmbBuscadorGlobal" Height="40" Margin="0,0,0,25" FontSize="14" VerticalContentAlignment="Center" 
                                      ItemsSource="{Binding ListaDestinatarios}" SelectedItem="{Binding DestinatarioSeleccionado}" IsEnabled="{Binding IsBuscadorHabilitado}"
                                      DisplayMemberPath="Nombre" SelectedValuePath="Id" Padding="10,0" Background="#F8F9FA"/>

                            <TextBlock Text="3. Contenido del Mensaje:" FontSize="15" FontWeight="Bold" Margin="0,0,0,10" Foreground="#2C3E50"/>
                            <TextBox x:Name="TxtContenidoGlobal" Height="160" TextWrapping="Wrap" AcceptsReturn="True" 
                                     Text="{Binding ContenidoMensaje, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,30" CharacterCasing="Upper" Padding="12" VerticalContentAlignment="Top" FontSize="14"
                                     BorderBrush="#BDC3C7" BorderThickness="1" Background="#FAFCFC"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Width="220" Height="45" Cursor="Hand" Command="{Binding EnviarMensajeCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="FondoBoton" Background="#00843D" CornerRadius="6">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <ui:SymbolIcon Symbol="Send24" Foreground="White" Margin="0,0,10,0" FontSize="20"/>
                                                    <TextBlock Text="Enviar Notificación" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="FondoBoton" Property="Background" Value="#00A84D"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="FondoBoton" Property="Background" Value="#005C2B"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <Border Grid.Column="2" Background="#F8F9F9" CornerRadius="10" Padding="20" BorderBrush="#EAEDED" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <ui:SymbolIcon Symbol="Archive24" Foreground="#7F8C8D" FontSize="22" Margin="0,0,10,0"/>
                                <TextBlock Text="Historial de Mensajes" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                            </StackPanel>

                            <ui:TextBox x:Name="TxtBuscarHistorial" PlaceholderText="Buscar en historial..." Icon="Search24" Text="{Binding TextoBusquedaHistorial, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="icHistorial" ItemsSource="{Binding ListaHistorialVisible}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" CornerRadius="6" Padding="15" Margin="0,0,5,10" BorderBrush="#D5D8DC" BorderThickness="1">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                                                        <TextBlock Text="{Binding Emisor}" FontWeight="SemiBold" FontSize="14" Foreground="#34495E" VerticalAlignment="Center"/>
                                                        <Border Background="#ECF0F1" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding TipoAlcance}" Foreground="#7F8C8D" FontSize="10" FontWeight="Bold"/>
                                                        </Border>
                                                    </StackPanel>

                                                    <Button Grid.Column="1" Width="28" Height="28" Cursor="Hand" ToolTip="Restaurar a la pantalla de inicio" Command="{Binding DataContext.RestaurarMensajeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding IdMensaje}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="FondoRestaurar" Background="Transparent" CornerRadius="4">
                                                                    <ui:SymbolIcon Symbol="ArrowUndo24" Foreground="#27AE60" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="FondoRestaurar" Property="Background" Value="#EAFAF1"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="FondoRestaurar" Property="Background" Value="#D5F5E3"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </Grid>

                                                <TextBlock Text="{Binding TextoMensaje}" TextWrapping="Wrap" FontSize="13" Foreground="#566573" LineHeight="18" Margin="0,0,0,8"/>

                                                <TextBlock Text="{Binding Fecha}" HorizontalAlignment="Right" Foreground="#BDC3C7" FontSize="11"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>