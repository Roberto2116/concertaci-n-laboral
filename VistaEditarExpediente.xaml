<ui:FluentWindow x:Class="Proyecto_GRRLN_expediente.VistaEditarExpediente"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Editar Asunto" Height="800" Width="1350"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Background="#F0F4F8" 
                 Loaded="UserControl_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Sistema de Expedientes - Modificación de Registro" />

        <Grid Grid.Row="1" Margin="25,10,25,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#EAECEE" CornerRadius="6" Padding="15,10" Margin="0,0,0,20">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Edit20" Foreground="#2C3E50" Margin="0,0,10,0"/>
                        <TextBlock x:Name="TxtTituloVista" Text="{Binding TituloVista}" Foreground="#2C3E50" FontWeight="Black" FontSize="18" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnAvance" Cursor="Hand" Command="{Binding AvanceCommand}" Margin="0,0,10,0">
                            <Button.Template>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border x:Name="FondoAvance" Background="#FDF2E9" CornerRadius="6" Padding="15,8">
                                        <TextBlock Text="Actualizar Avance" Foreground="#D35400" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="FondoAvance" Property="Background" Value="#FAE5D3"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BtnSeguimiento" Cursor="Hand" Command="{Binding SeguimientoCommand}" Margin="0,0,10,0">
                            <Button.Template>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border x:Name="FondoSeguimiento" Background="#EAF2F8" CornerRadius="6" Padding="15,8">
                                        <TextBlock Text="Ver Bitácora" Foreground="#2874A6" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="FondoSeguimiento" Property="Background" Value="#D4E6F1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BtnEliminar" Cursor="Hand" Width="40" Height="40" Command="{Binding EliminarCommand}" ToolTip="Eliminar Expediente">
                            <Button.Template>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border x:Name="FondoEliminar" Background="#FDEDEC" CornerRadius="20">
                                        <ui:SymbolIcon Symbol="Delete24" Foreground="#C0392B" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="FondoEliminar" Property="Background" Value="#FADBD8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5.5*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="4.5*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="Ámbito del Asunto a Tratar en la Agenda Laboral" FontWeight="Black" FontSize="15" Foreground="#0F172A" Padding="20">
                        <StackPanel Margin="0,15,0,0">

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Fecha Recepción:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <DatePicker Grid.Column="1" x:Name="DpFechaRecepcion" Height="35" FontSize="14" SelectedDate="{Binding FechaRecepcion, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Tipo:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <TextBox Grid.Column="4" x:Name="TxtTipo" Text="{Binding Tipo}" IsReadOnly="True" Background="#E2E8F0" Foreground="#475569" FontWeight="Bold" Height="35" FontSize="14" VerticalContentAlignment="Center" TextAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Documento No.:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <TextBox Grid.Column="1" x:Name="TxtNombreOficio" Text="{Binding NombreOficio, UpdateSourceTrigger=PropertyChanged}" Height="35" CharacterCasing="Upper" Padding="8,0" FontSize="14" VerticalContentAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Fecha del Doc.:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <DatePicker Grid.Column="1" x:Name="DpFechaOficio" SelectedDate="{Binding FechaOficio, UpdateSourceTrigger=PropertyChanged}" Height="35" FontSize="14" HorizontalAlignment="Left" Width="180"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="250"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Gerencia (SAP):" FontWeight="SemiBold"/>
                                </TextBlock>
                                <ComboBox Grid.Column="1" x:Name="CmbSAP" ItemsSource="{Binding ListaSAP}" SelectedValue="{Binding SapSeleccionado}" Height="35" FontSize="14" DisplayMemberPath="Descripcion" SelectedValuePath="Id" HorizontalAlignment="Left" Width="250"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="250"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Subgerencia (Org.):" FontWeight="SemiBold"/>
                                </TextBlock>
                                <ComboBox Grid.Column="1" x:Name="CmbOrganismo" ItemsSource="{Binding ListaOrganismo}" SelectedValue="{Binding OrganismoSeleccionado}" Height="35" FontSize="14" DisplayMemberPath="Descripcion" SelectedValuePath="Id" HorizontalAlignment="Left" Width="250"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Departamento:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <ComboBox Grid.Column="1" x:Name="CmbDepartamento" ItemsSource="{Binding ListaDepartamentos}" SelectedItem="{Binding DepartamentoSeleccionado}" Height="35" FontSize="14" DisplayMemberPath="Descripcion"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Agenda:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <ComboBox Grid.Column="1" x:Name="CmbAgenda" ItemsSource="{Binding ListaAgendas}" SelectedItem="{Binding AgendaSeleccionada}" Height="35" FontSize="14">
                                </ComboBox>

                                <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Sección:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <ComboBox Grid.Column="4" x:Name="CmbSecSindical" ItemsSource="{Binding ListaSecSindical}" SelectedValue="{Binding SecSindicalSeleccionada}" Height="35" FontSize="14" DisplayMemberPath="Descripcion" SelectedValuePath="Id"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Centro Trabajo:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <ComboBox Grid.Column="1" x:Name="CmbCentroTrabajo" ItemsSource="{Binding ListaCentrosTrabajo}" SelectedItem="{Binding CentroTrabajoSeleccionado}" Height="35" FontSize="14" DisplayMemberPath="Descripcion"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Tema:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <ComboBox Grid.Column="1" x:Name="CmbDescCorta" ItemsSource="{Binding ListaDescCorta}" SelectedValue="{Binding DescCortaSeleccionada}" Height="35" FontSize="14" DisplayMemberPath="Descripcion" SelectedValuePath="Id"/>
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Column="2" Header="Responsable en Atender el Asunto" FontWeight="Black" FontSize="15" Foreground="#0F172A" Padding="20">
                        <StackPanel Margin="0,15,0,0">

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Responsable:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <ComboBox Grid.Column="1" x:Name="CmbResponsable" ItemsSource="{Binding ListaResponsables}" SelectedValue="{Binding ResponsableSeleccionado}" IsEnabled="{Binding ResponsableEnabled}" Height="35" FontSize="14" DisplayMemberPath="Descripcion" SelectedValuePath="IdFicha"/>

                                <TextBlock Grid.Column="3" Text="Ficha:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBox Grid.Column="4" x:Name="TxtFichaVisual" Text="{Binding FichaVisual}" Height="35" FontSize="14" IsReadOnly="True" Background="#F1F5F9" FontWeight="Bold" Foreground="#64748B" VerticalContentAlignment="Center" TextAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" F. Compromiso:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <DatePicker Grid.Column="1" x:Name="DpFechaCompromiso" SelectedDate="{Binding FechaCompromiso, UpdateSourceTrigger=PropertyChanged}" Height="35" FontSize="14" HorizontalAlignment="Left" Width="180"/>
                            </Grid>

                            <TextBlock Text="Instrucciones para la atención:" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtInstruccion" Text="{Binding Instruccion, UpdateSourceTrigger=PropertyChanged}" Height="100" TextWrapping="Wrap" AcceptsReturn="True" CharacterCasing="Upper" Padding="8" FontSize="14" Margin="0,0,0,15"/>

                            <TextBlock Text="Observaciones a considerar en la Gestión del Asunto:" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtObservaciones" Text="{Binding Observaciones, UpdateSourceTrigger=PropertyChanged}" Height="100" TextWrapping="Wrap" AcceptsReturn="True" CharacterCasing="Upper" Padding="8" FontSize="14"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,10,0,0">
                <TextBlock Text="* Campos Obligatorios" Foreground="#D32F2F" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                    <Button Width="180" Height="45" Cursor="Hand" Command="{Binding RegresarCommand}" Margin="0,0,15,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="FondoBotonC" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <ui:SymbolIcon Symbol="Dismiss24" Foreground="#0F172A" Margin="0,0,10,0" FontSize="20"/>
                                        <TextBlock Text="Cancelar" Foreground="#0F172A" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="FondoBotonC" Property="Background" Value="#F8FAFC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Width="220" Height="45" Cursor="Hand" Command="{Binding GuardarCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="FondoBoton" Background="#2C3E50" CornerRadius="6">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <ui:SymbolIcon Symbol="Save24" Foreground="White" Margin="0,0,10,0" FontSize="20"/>
                                        <TextBlock Text="Guardar Cambios" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="FondoBoton" Property="Background" Value="#1A252F"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>