<ui:FluentWindow x:Class="Proyecto_GRRLN_expediente.VistaNuevoExpediente"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Registrar Nuevo Asunto" Height="900" Width="1600"
                 WindowStartupLocation="CenterScreen"
                 WindowState="Maximized"
                 ResizeMode="NoResize"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 Background="#F0F4F8" 
                 Loaded="UserControl_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Sistema de Expedientes - Nuevo Registro" 
                     ShowMinimize="False" 
                     ShowMaximize="False" 
                     ShowClose="False" />

        <Grid Grid.Row="1" Margin="25,10,25,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Asunto No." FontSize="18" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LblProximoFolio" Text="(New)" FontSize="26" FontWeight="Black" Foreground="#2196F3" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="1" Background="White" Padding="15,5" Margin="0,0,0,10" CornerRadius="4" BorderBrush="#E2E8F0" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Fecha:" Foreground="#64748B" FontWeight="Bold" Margin="0,0,10,5" TextAlignment="Right"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="LblFechaActual" Text="--" Foreground="#0F172A" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Usuario:" Foreground="#64748B" FontWeight="Bold" Margin="0,0,10,0" TextAlignment="Right"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="LblUsuarioActual" Text="--" Foreground="#0F172A" FontWeight="SemiBold"/>
                    </Grid>
                </Border>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5.5*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="4.5*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="Ámbito del Asunto a Tratar en la Agenda Laboral" FontWeight="Black" FontSize="15" Foreground="#0F172A" Padding="20">
                        <StackPanel Margin="0,15,0,0">

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Fecha Recepción:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <DatePicker Grid.Column="1" x:Name="DpFechaRecepcion" Height="35" FontSize="14" SelectedDateChanged="DpFechaRecepcion_SelectedDateChanged"/>

                                <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Tipo:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <TextBox Grid.Column="4" x:Name="TxtTipo" Text="CASO" IsReadOnly="True" Background="#E2E8F0" Foreground="#475569" FontWeight="Bold" Height="35" FontSize="14" VerticalContentAlignment="Center" TextAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Documento No.:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <TextBox Grid.Column="1" x:Name="TxtNombreOficio" Height="35" CharacterCasing="Upper" Padding="8,0" FontSize="14" VerticalContentAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Fecha del Doc.:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <DatePicker Grid.Column="1" x:Name="DpFechaOficio" Height="35" FontSize="14" HorizontalAlignment="Left" Width="180"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="250"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Gerencia (SAP):" FontWeight="SemiBold"/>
                                </TextBlock>
                                <ComboBox Grid.Column="1" x:Name="CmbSAP" Height="35" FontSize="14" DisplayMemberPath="Descripcion" SelectedValuePath="Id" HorizontalAlignment="Left" Width="250"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="250"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Subgerencia (Org.):" FontWeight="SemiBold"/>
                                </TextBlock>
                                <ComboBox Grid.Column="1" x:Name="CmbOrganismo" Height="35" FontSize="14" DisplayMemberPath="Descripcion" SelectedValuePath="Id" HorizontalAlignment="Left" Width="250"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Departamento:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <ComboBox Grid.Column="1" x:Name="CmbDepartamento" Height="35" FontSize="14" DisplayMemberPath="Descripcion" SelectedValuePath="Id"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Agenda:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <ComboBox Grid.Column="1" x:Name="CmbAgenda" Height="35" FontSize="14">
                                    <ComboBoxItem Content="ADMINISTRATIVA"/>
                                    <ComboBoxItem Content="SINDICAL"/>
                                </ComboBox>

                                <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Sección:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <ComboBox Grid.Column="4" x:Name="CmbSecSindical" Height="35" FontSize="14" DisplayMemberPath="Descripcion" SelectedValuePath="Id"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Centro Trabajo:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <ComboBox Grid.Column="1" x:Name="CmbCentroTrabajo" Height="35" FontSize="14" DisplayMemberPath="Descripcion" SelectedValuePath="Id" SelectionChanged="CmbCentroTrabajo_SelectionChanged"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Tema:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <ComboBox Grid.Column="1" x:Name="CmbDescCorta" Height="35" FontSize="14" DisplayMemberPath="Descripcion" SelectedValuePath="Id"/>
                            </Grid>

                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Column="2" Header="Responsable en Atender el Asunto" FontWeight="Black" FontSize="15" Foreground="#0F172A" Padding="20">
                        <StackPanel Margin="0,15,0,0">
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" Responsable:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <ComboBox Grid.Column="1" x:Name="CmbResponsable" Height="35" FontSize="14" DisplayMemberPath="Descripcion" SelectedValuePath="IdFicha" SelectionChanged="CmbResponsable_SelectionChanged"/>

                                <TextBlock Grid.Column="3" Text="Ficha:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBox Grid.Column="4" x:Name="TxtFichaVisual" Height="35" FontSize="14" IsReadOnly="True" Background="#F1F5F9" FontWeight="Bold" Foreground="#64748B" VerticalContentAlignment="Center" TextAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                    <Run Text="*" Foreground="#D32F2F" FontWeight="Bold"/>
                                    <Run Text=" F. Compromiso:" FontWeight="SemiBold"/>
                                </TextBlock>
                                <DatePicker Grid.Column="1" x:Name="DpFechaCompromiso" Height="35" FontSize="14" HorizontalAlignment="Left" Width="180"/>
                            </Grid>

                            <TextBlock Text="Instrucciones para la atención:" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtInstruccion" Height="100" TextWrapping="Wrap" AcceptsReturn="True" CharacterCasing="Upper" Padding="8" FontSize="14" Margin="0,0,0,15"/>

                            <TextBlock Text="Observaciones a considerar en la Gestión del Asunto:" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtObservaciones" Height="100" TextWrapping="Wrap" AcceptsReturn="True" CharacterCasing="Upper" Padding="8" FontSize="14"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,10,0,0">
                <TextBlock Text="* Campos Obligatorios" Foreground="#D32F2F" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Width="180" Height="45" Cursor="Hand" Click="BtnGuardar_Click" Margin="0,0,20,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="FondoBoton" Background="#00843D" CornerRadius="6">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <ui:SymbolIcon Symbol="Save24" Foreground="White" Margin="0,0,10,0" FontSize="20"/>
                                        <TextBlock Text="Guardar" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="FondoBoton" Property="Background" Value="#00A84D"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Width="180" Height="45" Cursor="Hand" Click="BtnRegresar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="FondoBotonC" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <ui:SymbolIcon Symbol="ArrowLeft24" Foreground="#0F172A" Margin="0,0,10,0" FontSize="20"/>
                                        <TextBlock Text="Regresar" Foreground="#0F172A" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="FondoBotonC" Property="Background" Value="#F8FAFC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>