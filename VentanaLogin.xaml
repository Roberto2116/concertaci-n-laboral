<ui:FluentWindow x:Class="Proyecto_GRRLN_expediente.VentanaLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Inicio de Sesión" Height="520" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" 
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Agenda Laboral" 
                     ShowMinimize="False" 
                     ShowMaximize="False" 
                     ShowClose="False" />

        <Grid Grid.Row="0" Height="6" VerticalAlignment="Top" Margin="0,32,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Border Background="#00843D" Grid.Column="0" CornerRadius="0,0,2,0"/>
            <Border Background="#C8102E" Grid.Column="1" CornerRadius="2,0,0,0"/>
        </Grid>

        <StackPanel Grid.Row="1" Margin="35,10,35,20" VerticalAlignment="Center">

            <Border Background="#E5F3EB" Width="70" Height="70" CornerRadius="35" Margin="0,0,0,15">
                <ui:SymbolIcon Symbol="BuildingBank24" FontSize="36" Foreground="#00843D" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="AGENDA LABORAL" FontSize="22" FontWeight="Black" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,2"/>

            <TextBlock Text="FICHA DE EMPLEADO" FontSize="11" FontWeight="Bold" Foreground="#7F8C8D" Margin="0,0,0,5" />

            <ui:TextBox x:Name="TxtUsuario" Text="{Binding Usuario, UpdateSourceTrigger=PropertyChanged}" Height="42" PlaceholderText="Ej. 1001" Icon="Person24" ClearButtonEnabled="True" Margin="0,0,0,20" FontSize="14" BorderBrush="#E0E0E0"/>

            <TextBlock Text="CONTRASEÑA" FontSize="11" FontWeight="Bold" Foreground="#7F8C8D" Margin="0,0,0,5" />

            <ui:PasswordBox x:Name="TxtPassword" Height="34" PlaceholderText="Ingresa tu clave..." Icon="Key24" Margin="0,0,0,10" FontSize="14" BorderBrush="#E0E0E0"/>

            <TextBlock x:Name="LblError" Text="{Binding MensajeError}" Foreground="#C8102E" 
                       FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" 
                       Visibility="{Binding IsErrorVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,15"/>

            <Button x:Name="BtnEntrar" Height="45" Margin="0,15,0,15" Cursor="Hand" 
                    Command="{Binding EntrarCommand}" CommandParameter="{Binding ElementName=TxtPassword}" IsDefault="True">
                <Button.Template>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="FondoBoton" Background="#00843D" CornerRadius="6">

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="Key24" Foreground="White" Margin="0,0,10,0" FontSize="20"/>
                                <TextBlock Text="INGRESAR AL SISTEMA" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FondoBoton" Property="Background" Value="#00A84D"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FondoBoton" Property="Background" Value="#005C2B"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FondoBoton" Property="Background" Value="#BDC3C7"/>
                                <Setter Property="Foreground" Value="#7F8C8D"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Button.Template>
            </Button>

            <ui:Button Content="Cerrar aplicación" Appearance="Transparent" Foreground="#7F8C8D" HorizontalAlignment="Center" Cursor="Hand" Command="{Binding SalirCommand}"/>

        </StackPanel>
    </Grid>
</ui:FluentWindow>